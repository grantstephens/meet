# LiveKit Cloud Configuration
# Get your API key, secret, and URL from https://cloud.livekit.io/
#
# For development: Copy this file to .env.local (for Next.js)
# For Docker: Copy this file to .env (for docker-compose)

LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud
